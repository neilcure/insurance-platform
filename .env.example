# Database (Neon PostgreSQL)
# In production prefer Neon's POOLED URL (host contains "-pooler") so warm
# serverless instances don't exhaust the project's connection limit.
DATABASE_URL=postgresql://user:password@your-project.aws.neon.tech/neondb?sslmode=require

# Optional pool tuning. Default DB_POOL_MAX=5 is safe for serverless
# (each warm instance opens its own pool, so total connections =
# DB_POOL_MAX × warm instance count). Raise to 10–20 only on a single
# long-running Node host. DB_IDLE_TIMEOUT is in seconds.
# DB_POOL_MAX=5
# DB_IDLE_TIMEOUT=20

# NextAuth
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Edge auth-middleware kill switch. Set to "1" to disable the
# auth proxy in proxy.ts (per-route requireUser checks still
# enforce auth). Useful for emergency recovery if a release blocks
# a public endpoint.
# DISABLE_AUTH_MIDDLEWARE=0

# Active-organisation strict mode. When unset, routes that don't
# receive an explicit `organisationId` fall back to the user's first
# membership (legacy behavior) and emit a warn log. Set to "1" to
# turn the fallback into a 400 response — flip this only after the
# `[active-org] silent fallback` warnings stop appearing in logs.
# STRICT_ACTIVE_ORG=0

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brevo Email (optional)
BREVO_API_KEY=
BREVO_SENDER=noreply@yourdomain.com
BREVO_SENDER_NAME=Insurance Platform

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=

# App
APP_URL=https://yourdomain.com

# Cron secret for scheduled tasks
CRON_SECRET=generate-a-random-secret-here
